#!/bin/sh
# .docker/start-container
# RIYO+ Container Start Script

set -e

echo "🚀 Starting RIYO+ Container..."

# ============================================================
# Create OPcache directory at runtime (just in case)
# ============================================================
mkdir -p /tmp/opcache
chmod 777 /tmp/opcache

# ============================================================
# Verify OPcache configuration
# ============================================================
echo "🔧 OPcache file_cache: $(php -r "echo ini_get('opcache.file_cache') ?: 'not set';")"

# ============================================================
# Run migrations (if not already run)
# ============================================================
if [ -f artisan ]; then
    php artisan migrate --force || echo "⚠️ Migration failed, continuing..."
fi

# ============================================================
# Clear and cache config
# ============================================================
php artisan config:cache
php artisan route:cache
php artisan view:cache

# ============================================================
# Start Supervisor
# ============================================================
echo "✅ Starting Supervisor..."
exec /usr/bin/supervisord -c /etc/supervisor/supervisord.conf
